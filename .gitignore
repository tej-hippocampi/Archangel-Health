# Secrets — never commit
backend/.env
**/.env
*.env
sendgrid.env
# Backup copies of env files (often contain real keys)
.env.bak*
**/.env.bak*

# Cursor (editor / agent local state — do not commit)
.cursor/

# Temporary design exports / flat unpacks (local scratch only)
.tmp-flat/

# Local ZIP bundles exported for one-off sharing (prefer source commits)
*.zip

# Python
__pycache__/
*.pyc
*.pyo
.venv/
venv/
*.egg-info/

# macOS
.DS_Store

# Auth (user store — do not commit)
backend/auth_users.json

# Demo patient roster snapshot (PII-shaped demo data)
backend/demo_patient_store.json

# Local SQLite (team / onboarding state — do not commit)
backend/*.db
backend/*.db-journal
backend/*.db-wal
backend/*.db-shm

# Landing (dependencies and build)
landing/node_modules/
landing/dist/
