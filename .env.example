# ═══════════════════════════════════════════════════════════
#  CareGuide — Environment Variables
#  Copy to .env and fill in your values.
#  NEVER commit .env to version control.
# ═══════════════════════════════════════════════════════════

# ── Anthropic (Claude) ──────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...

# ── ElevenLabs (voice synthesis) ────────────────────────────
ELEVENLABS_API_KEY=...
# Choose a warm, calm clinical voice from ElevenLabs voice library
ELEVENLABS_VOICE_ID=EXAVITQu4vr4xnSDxMaL

# ── Tavus (AI avatar) ────────────────────────────────────────
TAVUS_API_KEY=...
# Your licensed replica ID (the visual avatar face/body)
TAVUS_REPLICA_ID=r...

# ── Daily.co (human telehealth video) ─────────────────────────
VIDEO_PROVIDER=daily
DAILY_API_KEY=...
# Your Daily subdomain, e.g. yourteam.daily.co
DAILY_DOMAIN=yourteam.daily.co

# ── Twilio (SMS delivery) ────────────────────────────────────
TWILIO_ACCOUNT_SID=AC...
TWILIO_AUTH_TOKEN=...
TWILIO_FROM_NUMBER=+1...

# ── Email (SendGrid Web API — preferred for "Send to Patient") ────────
SENDGRID_API_KEY=SG....
# Verified sender address (e.g. noreply@archangelhealth.ai)
SENDGRID_FROM_EMAIL=noreply@archangelhealth.ai
# Same address must be verified in SendGrid (Single Sender or domain auth) or health-system onboarding OTP emails return 503.
# If you only completed Single Sender Verification for a personal Gmail, set SENDGRID_FROM_EMAIL to that exact address until your domain is authenticated.
SENDGRID_FROM_NAME=Archangel Health

# ── Email fallback (SMTP — only if SENDGRID_API_KEY not set) ────────
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=your-email@gmail.com
# SMTP_PASS=your-app-password

# ── Demo mode (local / staging demos) ────────────────────────
# DEMO_MODE=1 enables seeded demo roster (see backend/main.py).
# TRIAGE demo tenant seed (Dr. Thompson / RN Castillo roster). Keep enabled for
# product demos; disable in production if you do not want TRIAGEDM data loaded.
# ENABLE_TRIAGE_DEMO=1
# Demo credential secrets (set strong values outside local dev).
# DEMO_DOCTOR_PASSWORD=...
# TRIAGE_DEMO_SURGEON_PASSWORD=...
# TRIAGE_DEMO_RN_PASSWORD=...
# The shared marketing landing demo user (DEMO_DOCTOR_EMAIL in main.py) is created on startup unless disabled:
# DISABLE_PUBLIC_DEMO_ACCOUNT=1
# DEMO_MODE=1
# Persist in-memory patient roster across restarts (JSON). Default on when DEMO_MODE=1; set 0 for a fresh roster every boot.
# DEMO_PERSIST_PATIENT_STORE=1
# Optional absolute path; default is backend/demo_patient_store.json next to main.py.
# DEMO_PATIENT_STORE_PATH=/var/data/demo_patient_store.json
# SQLite for episodes/surveys/events — use a mounted path in Docker so team activity survives redeploys.
# TEAM_DB_PATH=/var/data/team.db
# Intake bot v2 APIs + structured intake workflow (set 0 to disable quickly during rollout).
# ENABLE_PREOP_INTAKE_BOT_V2=1

# ── App ──────────────────────────────────────────────────────
# Public URL where patients will access their dashboard
BASE_URL=https://app.careguide.com
# Landing page URL (for "View your recovery plan" in patient emails). Required so patients get the code-entry page; if unset, the link goes to the patient dashboard directly.
# LANDING_URL=http://localhost:5173
# Secret for JWT signing (landing / Elysium Health auth + patient sessions).
# Use a long random string in production.
AUTH_SECRET=change-me-in-production-elysium
# Deployment environment. Set ENV=production to mark patient-session cookies
# Secure (HTTPS-only). Anything else (or unset) keeps cookies usable over plain
# http for local dev. Future PRDs also gate HSTS/HTTPS redirect on ENV=production.
# ENV=production
# Patient PHI access control (PRD-1). Default ON: patient routes require a patient
# session (entered via clinic_code + resource_code) or scoped clinical staff. Set
# to 0 ONLY for a brief staged rollback — it re-opens unauthenticated patient
# access and logs a warning on every such request. Remove once rollout is verified.
# ENFORCE_PATIENT_AUTH=1
# Care team callback number shown in the dashboard footer (fallback when doctor office_phone not set)
CARE_TEAM_PHONE=+1...

# ── HTTP security hardening (PRD-2) ──────────────────────────────────────────
# Comma-separated CORS allowlist. Defaults to BASE_URL + LANDING_URL when unset.
# In production, include the landing app origin so its cross-origin /api calls work.
# ALLOWED_ORIGINS=https://app.archangelhealth.ai,https://archangelhealth.ai
# Comma-separated Host allowlist (TrustedHostMiddleware). Only enforced when ENV=production.
# ALLOWED_HOSTS=app.archangelhealth.ai,archangelhealth.ai
# App-level HTTP->HTTPS redirect. OFF by default — HSTS + the platform edge already
# force HTTPS. Enable ONLY if uvicorn runs with --proxy-headers (it does in the
# Dockerfile/Procfile); otherwise it loops forever behind a TLS-terminating proxy.
# FORCE_HTTPS_REDIRECT=0
# Content-Security-Policy starts in report-only (1). Flip to 0 to enforce (phase 2).
# CSP_REPORT_ONLY=1
# Application-layer brute-force rate limiting on auth/code/OTP routes. Default on.
# RATE_LIMIT_ENABLED=1
# Require staff to have TOTP MFA enrolled before they can log in (PRD-3). Default
# off (MFA is opt-in per account). Turn on only after enrollment UI is rolled out,
# or unenrolled users will be blocked at login with a 403.
# REQUIRE_STAFF_MFA=0

# ── Subprocessor BAA gate (PRD-4) ────────────────────────────────────────────
# Set a flag to 1 ONLY once a signed Business Associate Agreement is actually on
# file for that vendor. Until then we send de-identified content (voice/avatar) or
# strip PHI (email). Anthropic first-party API and Twilio SMS default to covered.
# ANTHROPIC_BAA_SIGNED=1
# TWILIO_BAA_SIGNED=1
# SENDGRID is not HIPAA-eligible — leave this UNSET unless you truly have a BAA:
# SENDGRID_BAA_SIGNED=0
# ELEVENLABS_BAA_SIGNED=0
# TAVUS_BAA_SIGNED=0

# ── Encryption at rest (PRD-6) ───────────────────────────────────────────────
# AES-256-GCM field encryption for PHI written to disk (patient-store snapshot).
# Base64-encoded 32-byte key — generate with:
#   python3 -c "import os,base64; print(base64.b64encode(os.urandom(32)).decode())"
# Inject from a KMS / Secrets Manager in production. If unset, PHI fields are
# written unencrypted and the app relies on the platform's volume encryption only.
# DATA_ENCRYPTION_KEY=
# DATA_ENCRYPTION_KEY_VERSION=1
# Key rotation: keep old keys here (decrypt-only) as "ver:base64,ver:base64".
# DATA_ENCRYPTION_KEY_RING=

# ── Asclepius — Expert Evaluation Portal (Product #3, standalone, no PHI) ─────
# Own SQLite DB (never touches team.db). Default: backend/asclepius.db
# ASCLEPIUS_DB_PATH=/var/data/asclepius.db
# Standalone JWT signing secret (independent of AUTH_SECRET). REQUIRED + strong
# (>=16 chars) in production; dev falls back to an ephemeral per-process secret.
ASCLEPIUS_AUTH_SECRET=change-me-asclepius
# Where export batches (JSONL + datasheet + dictionary + quality report) are written.
# ASCLEPIUS_EXPORT_DIR=/tmp/asclepius-exports
# Human-QA sampling rate (%). All flagged records are reviewed regardless. 0 = none, 100 = all.
ASCLEPIUS_QA_SAMPLE_PCT=15
# Submissions faster than this many seconds are flagged "too_fast" and routed to QA.
ASCLEPIUS_TIME_FLOOR_SEC=20
# Optional per-role model overrides (default claude-sonnet-4-6 via MODEL_REGISTRY):
# MODEL_ASCLEPIUS_CRITIC=claude-sonnet-4-6
# MODEL_ASCLEPIUS_CANDIDATE_GEN=claude-sonnet-4-6
# ── Seedmaker auto-generation (Mode A, nephrology v1 — PRD §11) ──
# Prompt synthesis + error-likelihood judging default to the strongest model
# (claude-opus-4-8) for highest-quality, high-value prompts. Override to a
# lighter model (e.g. claude-sonnet-4-6) only if cost/availability requires it.
# Candidate gen stays on the current (non-max) model so realistic, revisable
# errors are more likely.
# MODEL_ASCLEPIUS_PROMPT_GEN=claude-sonnet-4-6
# MODEL_ASCLEPIUS_PROMPT_JUDGE=claude-sonnet-4-6
# Quality gate: drop generated items below these judge scores (0..1).
ASCLEPIUS_GEN_MIN_ERROR_LIKELIHOOD=0.5
ASCLEPIUS_GEN_MIN_REVISION_VALUE=0.5
# Generation attempts before giving up on one task slot (avoids infinite loops).
ASCLEPIUS_GEN_MAX_ATTEMPTS_PER_TASK=4
# Seed exemplars sampled per prompt-generation call (few-shot K).
ASCLEPIUS_GEN_FEWSHOT_K=6
# Bootstrap admin seeded on first boot if the user table is empty (rotate immediately):
# ASCLEPIUS_ADMIN_EMAIL=admin@asclepius.local
# ASCLEPIUS_ADMIN_PASSWORD=change-me-strong
# Seed a demo evaluator on first boot (local/demo convenience). Set 0 to disable.
# ASCLEPIUS_SEED_DEMO_EVALUATOR=1
# ASCLEPIUS_DEMO_EVALUATOR_EMAIL=evaluator@asclepius.local
# ASCLEPIUS_DEMO_EVALUATOR_PASSWORD=change-me-strong
# ASCLEPIUS_DEMO_EVALUATOR_SPECIALTY=nephrology
# ── Mock / sandbox contributor (internal demo tool) ──
# A stable evaluator login for exercising the LIVE portal (V3, multimodal cases)
# whose submissions are HARD-EXCLUDED from every export by default and labeled
# "Mock Contributor Account" in the admin. Provisioned idempotently on every boot
# (all environments). Surfaced in the admin Demo Credentials section with an
# "Open Asclepius portal" button. Set ASCLEPIUS_MOCK_ENABLED=0 to disable.
# Login is a plain username/id (the portal login accepts a username OR an email).
# ASCLEPIUS_MOCK_ENABLED=1
# ASCLEPIUS_MOCK_ID=mockadmin
# ASCLEPIUS_MOCK_PASSWORD=MockContributor-2026
# ASCLEPIUS_MOCK_SPECIALTY=nephrology
# ASCLEPIUS_MOCK_BOARD_CERT=board_certified_nephrology
# ASCLEPIUS_MOCK_YEARS=12
# ASCLEPIUS_MOCK_ORG=Archangel Health (Sandbox)
# ── Data optimization (opt prompt) ──
# Per-record rights attestation stamped on every exported record (opt §1.4).
# ASCLEPIUS_LICENSE=CC-BY-NC-4.0-clinical-eval
# ASCLEPIUS_IP_CLEARED=1
# % of tasks to double-label for Cohen's kappa inter-annotator agreement (opt §1.3).
# ASCLEPIUS_DOUBLE_LABEL_PCT=0
# Override the buyer-profile directory (default: backend/asclepius/buyer_profiles).
# ASCLEPIUS_PROFILES_DIR=

# ── Internal Tools ────────────────────────────────────────────
INTERNAL_TOOL_SECRET=change-me-internal-secret
# Admin portal login (admin.archangelhealth.ai)
ADMIN_USERNAME=admin
ADMIN_PASSWORD=change-me-strong-password

# ── Gold Standard — conversation-capture training data (Data Training tab) ───
# Backend mounted; UI box is a disabled placeholder for now. All vars optional
# (gold/config.py has safe defaults). Audio is PHI — leave STT BAA flags UNSET
# until a BAA is executed.
# STT_PROVIDER=whisper            # whisper | deepgram | stub
# WHISPER_API_KEY=sk-...          # or OPENAI_API_KEY
# WHISPER_MODEL=whisper-1
# DEEPGRAM_API_KEY=...
# DEEPGRAM_MODEL=nova-2-medical
# GOLD_DEID_PROVIDER=llm
# MODEL_GOLD_DRAFT_NOTE=claude-sonnet-4-6
# MODEL_GOLD_DEID=claude-sonnet-4-6
# GOLD_DEFAULT_SPECIALTY=general_surgery
# GOLD_AUDIO_RETENTION_DAYS=30
# GOLD_BAA_ON_FILE=1
# WHISPER_BAA_SIGNED=0
# DEEPGRAM_BAA_SIGNED=0
